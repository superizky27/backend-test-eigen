generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Book {
  id     Int    @id @default(autoincrement())
  code   String @unique
  title  String
  author String
  stock  Int

  borrows Borrow[]
}

model Member {
  id         Int    @id @default(autoincrement())
  code       String @unique
  name       String
  penaltyEnd DateTime?

  borrows Borrow[]
}

model Borrow {
  id         Int      @id @default(autoincrement())
  memberId   Int
  bookId     Int
  borrowDate DateTime

  member Member @relation(fields: [memberId], references: [id])
  book   Book   @relation(fields: [bookId], references: [id])
}